# Palantir Environment Variables
# Copy this to .env and fill in your values

# LLM provider: set ONE of the following.
# Anthropic is preferred when both are set (higher quality + vision).
# Groq is a free-tier alternative handy for development.
ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# Web UI auth token (auto-generated by install.sh if empty)
PALANTIR_AUTH_TOKEN=

# Redis connection
REDIS_URL=unix:///var/run/redis/redis.sock

# Database path
PALANTIR_DB_PATH=/var/lib/palantir/palantir.db

# Enrollment data path
PALANTIR_ENROLLMENT_PATH=/var/lib/palantir/enrollments
