# Palintir Environment Variables
# Copy this to .env and fill in your values

# Anthropic API key (required for LLM + vision)
ANTHROPIC_API_KEY=sk-ant-...

# Web UI auth token (auto-generated by install.sh if empty)
PALINTIR_AUTH_TOKEN=

# Redis connection
REDIS_URL=unix:///var/run/redis/redis.sock

# Database path
PALINTIR_DB_PATH=/var/lib/palintir/palintir.db

# Enrollment data path
PALINTIR_ENROLLMENT_PATH=/var/lib/palintir/enrollments
