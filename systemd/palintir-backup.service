[Unit]
Description=Palintir Database Backup
After=palintir-eventlog.service
# Oneshot — runs, backs up, exits. Triggered by palintir-backup.timer.

[Service]
Type=oneshot
User=palintir
Group=palintir
WorkingDirectory=/opt/palintir
Environment=PALINTIR_ENV=production
EnvironmentFile=/opt/palintir/.env
ExecStart=/opt/palintir/.venv/bin/palintir-backup
StandardOutput=journal
StandardError=journal

NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/var/lib/palintir
